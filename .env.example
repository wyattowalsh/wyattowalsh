# GitHub token for local development only; store real values in .env and rotate immediately if exposed
GITHUB_TOKEN=replace-with-github-token

# Optional: WakaTime API key for coding stats
# WAKATIME_API_KEY=

# Canonical profile workflow expects this PAT for rich repository-aware metrics cards.
# Recommended scopes: read:user, public_repo (add read:org for org/collab visibility).
# METRICS_TOKEN=

# Docs admin auth and telemetry
DOCS_ADMIN_PASSWORD=replace-with-a-shared-password
DOCS_ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
DOCS_TELEMETRY_STORE_PATH=.telemetry/store.json
DOCS_TELEMETRY_RETENTION_DAYS=30
DOCS_TELEMETRY_MAX_EVENTS=2500

# Canonical profile workflow expects the full Spotify OAuth trio for the music panel on
# metrics.additional.svg. Missing values disable that panel and the workflow will keep
# the last valid asset instead of committing placeholder output.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REFRESH_TOKEN=
