# GitHub Personal Access Token (required for GraphQL queries, higher rate limits)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: WakaTime API key for coding stats
# WAKATIME_API_KEY=

# Optional: Metrics token (GitHub PAT with read:user, public_repo)
# METRICS_TOKEN=

# Docs admin auth and telemetry
DOCS_ADMIN_PASSWORD=replace-with-a-shared-password
DOCS_ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
DOCS_TELEMETRY_STORE_PATH=.telemetry/store.json
DOCS_TELEMETRY_RETENTION_DAYS=30
DOCS_TELEMETRY_MAX_EVENTS=2500
DOCS_TELEMETRY_REDIS_REST_URL=
DOCS_TELEMETRY_REDIS_REST_TOKEN=
DOCS_TELEMETRY_REDIS_KEY=docs:telemetry:store

# Optional: Spotify integration
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REFRESH_TOKEN=
